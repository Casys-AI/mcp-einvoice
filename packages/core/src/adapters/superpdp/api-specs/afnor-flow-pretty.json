    "securitySchemes": {
      "BearerAuth": {
        "description": "Use authorization code to access data of another user after he gives his consent.\nUse client credentials to access your own data (similar to api key)",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "/oauth2/authorize",
            "scopes": {},
            "tokenUrl": "/oauth2/token"
