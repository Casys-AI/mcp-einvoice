# ===================
# MCP einvoice — Environment Variables
# ===================

# Adapter to use (iopole | storecove | superpdp | choruspro)
EINVOICE_ADAPTER=iopole

# ===================
# Iopole — OAuth2 Client Credentials
# ===================
# Pre-prod: api.ppd.iopole.fr
# Prod: api.iopole.com
IOPOLE_API_URL=https://api.ppd.iopole.fr/v1
IOPOLE_CLIENT_ID=your-email@example.com
IOPOLE_CLIENT_SECRET=your-client-secret
IOPOLE_CUSTOMER_ID=your-customer-id
IOPOLE_AUTH_URL=https://auth.ppd.iopole.fr/realms/iopole/protocol/openid-connect/token

# ===================
# Storecove — API Key
# ===================
# Same URL for sandbox and production (access scoped by API key)
STORECOVE_API_URL=https://api.storecove.com/api/v2
STORECOVE_API_KEY=your-api-key
# Optional: default legal entity ID for document submissions
# STORECOVE_LEGAL_ENTITY_ID=12345

# ===================
# Super PDP — OAuth2 Client Credentials
# ===================
SUPERPDP_API_URL=https://api.superpdp.tech/v1.beta
SUPERPDP_CLIENT_ID=your-client-id
SUPERPDP_CLIENT_SECRET=your-client-secret
# Optional: override token endpoint (default: https://api.superpdp.tech/oauth2/token)
# SUPERPDP_AUTH_URL=https://api.superpdp.tech/oauth2/token
# Optional: override AFNOR Flow API base URL (default: https://api.superpdp.tech/afnor-flow)
# SUPERPDP_AFNOR_URL=https://api.superpdp.tech/afnor-flow

# ===================
# Chorus Pro — OAuth2 (PISTE) + Technical Account
# ===================
# Sandbox: sandbox-api.piste.gouv.fr/cpro
# Prod: api.piste.gouv.fr/cpro
CHORUSPRO_API_URL=https://sandbox-api.piste.gouv.fr/cpro
CHORUSPRO_CLIENT_ID=your-piste-client-id
CHORUSPRO_CLIENT_SECRET=your-piste-client-secret
CHORUSPRO_LOGIN=TECH_1_xxxxx@cpro.fr
CHORUSPRO_PASSWORD=your-technical-account-password
# Optional: override token endpoint (default: sandbox)
# CHORUSPRO_AUTH_URL=https://sandbox-oauth.piste.gouv.fr/api/oauth/token
