{
  "name": "@casys/mcp-einvoice",
  "version": "0.1.1",
  "description": "PA-agnostic MCP tools for French e-invoicing. Currently implemented: Iopole (REST/JSON).",
  "nodeModulesDir": "auto",
  "tasks": {
    "serve": "deno run --allow-all server.ts --http --port=3015",
    "compile": "deno compile -A --output mcp-einvoice server.ts",
    "test": "deno test --allow-all src/",
    "ui:build": "cd src/ui && node build-all.mjs",
    "ui:watch": "deno run --allow-read --allow-run watch-ui.ts",
    "build:node": "./scripts/build-node.sh",
    "inspect": "deno run --allow-all server.ts --inspect"
  },
  "exports": {
    ".": "./mod.ts",
    "./server": "./server.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "server.ts",
      "src/**/*.ts",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*_test.ts",
      "**/*.test.ts",
      "**/*.bench.ts"
    ]
  },
  "imports": {
    "@casys/mcp-server": "jsr:@casys/mcp-server@^0.9.0"
  }
}
